{
  "info": {
    "name": "Equipment Rental and Booking Management System",
    "description": "Complete API collection for Equipment Rental and Booking Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [{ "key": "base_url", "value": "http://localhost:8000", "type": "string" }],
  "item": [
    {
      "name": "🔐 Common",
      "item": [
        { "name": "Signup", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/signup", "host": ["{{base_url}}"], "path": ["signup"] }, "body": { "mode": "raw", "raw": "{\n  \"name\": \"Karan Desai\",\n  \"email\": \"karan@gmail.com\",\n  \"phone\": \"9900000002\",\n  \"password\": \"Karan@123\"\n}" } } },
        { "name": "Login (User)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] }, "body": { "mode": "raw", "raw": "{\n  \"email\": \"karan@gmail.com\",\n  \"password\": \"Karan@123\"\n}" } } },
        { "name": "Login (Admin)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] }, "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@equipment.com\",\n  \"password\": \"Admin@123\"\n}" } } },
        { "name": "Logout", "request": { "method": "GET", "url": { "raw": "{{base_url}}/logout", "host": ["{{base_url}}"], "path": ["logout"] } } },
        { "name": "Session", "request": { "method": "GET", "url": { "raw": "{{base_url}}/session", "host": ["{{base_url}}"], "path": ["session"] } } },
        { "name": "Change Password", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/changePassword", "host": ["{{base_url}}"], "path": ["changePassword"] }, "body": { "mode": "raw", "raw": "{\n  \"email\": \"karan@gmail.com\",\n  \"newPassword\": \"NewPass@123\"\n}" } } }
      ]
    },
    {
      "name": "🌐 Public",
      "item": [
        { "name": "Get All Categories", "request": { "method": "GET", "url": { "raw": "{{base_url}}/categories", "host": ["{{base_url}}"], "path": ["categories"] } } },
        { "name": "Get All Equipment", "request": { "method": "GET", "url": { "raw": "{{base_url}}/equipment", "host": ["{{base_url}}"], "path": ["equipment"] } } },
        { "name": "Get Equipment — Filter by Category", "request": { "method": "GET", "url": { "raw": "{{base_url}}/equipment?category_id=CATEGORY_ID_HERE", "host": ["{{base_url}}"], "path": ["equipment"], "query": [{ "key": "category_id", "value": "CATEGORY_ID_HERE" }] } } },
        { "name": "Get Equipment — Filter by Price Range", "request": { "method": "GET", "url": { "raw": "{{base_url}}/equipment?min_price=400&max_price=1000", "host": ["{{base_url}}"], "path": ["equipment"], "query": [{ "key": "min_price", "value": "400" }, { "key": "max_price", "value": "1000" }] } } },
        { "name": "Get Equipment Details", "request": { "method": "GET", "url": { "raw": "{{base_url}}/equipment/EQUIPMENT_ID_HERE", "host": ["{{base_url}}"], "path": ["equipment", "EQUIPMENT_ID_HERE"] } } },
        { "name": "Get All Feedbacks", "request": { "method": "GET", "url": { "raw": "{{base_url}}/feedbacks", "host": ["{{base_url}}"], "path": ["feedbacks"] } } }
      ]
    },
    {
      "name": "🟢 User (Session Required)",
      "item": [
        { "name": "Get Profile", "request": { "method": "GET", "url": { "raw": "{{base_url}}/user/profile", "host": ["{{base_url}}"], "path": ["user", "profile"] } } },
        { "name": "Update Profile (with image)", "request": { "method": "POST", "url": { "raw": "{{base_url}}/user/updateProfile", "host": ["{{base_url}}"], "path": ["user", "updateProfile"] }, "body": { "mode": "formdata", "formdata": [{ "key": "name", "value": "Karan Kumar Desai", "type": "text" }, { "key": "phone", "value": "9911111111", "type": "text" }, { "key": "profile_image", "src": "", "type": "file" }] } } },
        { "name": "Place Booking", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/user/placeBooking", "host": ["{{base_url}}"], "path": ["user", "placeBooking"] }, "body": { "mode": "raw", "raw": "{\n  \"equip_id\": \"EQUIPMENT_ID_HERE\",\n  \"start_date\": \"2026-02-01\",\n  \"end_date\": \"2026-02-05\",\n  \"quantity\": 2\n}" } } },
        { "name": "My Bookings", "request": { "method": "GET", "url": { "raw": "{{base_url}}/user/myBookings", "host": ["{{base_url}}"], "path": ["user", "myBookings"] } } },
        { "name": "Cancel Booking", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/user/cancelBooking", "host": ["{{base_url}}"], "path": ["user", "cancelBooking"] }, "body": { "mode": "raw", "raw": "{\n  \"booking_id\": \"BOOKING_ID_HERE\"\n}" } } },
        { "name": "Generate Razorpay Order ID", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/user/genOrderId", "host": ["{{base_url}}"], "path": ["user", "genOrderId"] }, "body": { "mode": "raw", "raw": "{\n  \"booking_id\": \"BOOKING_ID_HERE\"\n}" } } },
        { "name": "Verify Razorpay Payment", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/user/verifyPayment", "host": ["{{base_url}}"], "path": ["user", "verifyPayment"] }, "body": { "mode": "raw", "raw": "{\n  \"booking_id\": \"BOOKING_ID_HERE\",\n  \"razorpay_order_id\": \"order_XXXX\",\n  \"razorpay_payment_id\": \"pay_XXXX\",\n  \"razorpay_signature\": \"sig_XXXX\"\n}" } } },
        { "name": "Add Feedback", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/user/addFeedback", "host": ["{{base_url}}"], "path": ["user", "addFeedback"] }, "body": { "mode": "raw", "raw": "{\n  \"booking_id\": \"BOOKING_ID_HERE\",\n  \"service_id\": \"EQUIPMENT_ID_HERE\",\n  \"rating\": 5,\n  \"feedback\": \"Excellent equipment quality. Well maintained and easy to use.\"\n}" } } }
      ]
    },
    {
      "name": "🔴 Admin (Session Required)",
      "item": [
        { "name": "Get All Users", "request": { "method": "GET", "url": { "raw": "{{base_url}}/admin/users", "host": ["{{base_url}}"], "path": ["admin", "users"] } } },
        { "name": "Update User Status (Activate)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/admin/updateUserStatus", "host": ["{{base_url}}"], "path": ["admin", "updateUserStatus"] }, "body": { "mode": "raw", "raw": "{\n  \"user_id\": \"USER_ID_HERE\",\n  \"status\": \"Active\"\n}" } } },
        { "name": "Update User Status (Deactivate)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/admin/updateUserStatus", "host": ["{{base_url}}"], "path": ["admin", "updateUserStatus"] }, "body": { "mode": "raw", "raw": "{\n  \"user_id\": \"USER_ID_HERE\",\n  \"status\": \"Inactive\"\n}" } } },
        { "name": "Add Category (with image)", "request": { "method": "POST", "url": { "raw": "{{base_url}}/admin/addCategory", "host": ["{{base_url}}"], "path": ["admin", "addCategory"] }, "body": { "mode": "formdata", "formdata": [{ "key": "name", "value": "Camera & Photography", "type": "text" }, { "key": "image", "src": "", "type": "file" }] } } },
        { "name": "Update Category (with image)", "request": { "method": "POST", "url": { "raw": "{{base_url}}/admin/updateCategory", "host": ["{{base_url}}"], "path": ["admin", "updateCategory"] }, "body": { "mode": "formdata", "formdata": [{ "key": "id", "value": "CATEGORY_ID_HERE", "type": "text" }, { "key": "name", "value": "Professional Cameras", "type": "text" }, { "key": "status", "value": "Active", "type": "text" }, { "key": "image", "src": "", "type": "file" }] } } },
        { "name": "Delete Category", "request": { "method": "GET", "url": { "raw": "{{base_url}}/admin/deleteCategory/CATEGORY_ID_HERE", "host": ["{{base_url}}"], "path": ["admin", "deleteCategory", "CATEGORY_ID_HERE"] } } },
        { "name": "Get All Categories (Admin)", "request": { "method": "GET", "url": { "raw": "{{base_url}}/admin/categories", "host": ["{{base_url}}"], "path": ["admin", "categories"] } } },
        { "name": "Add Equipment (with image)", "request": { "method": "POST", "url": { "raw": "{{base_url}}/admin/addEquipment", "host": ["{{base_url}}"], "path": ["admin", "addEquipment"] }, "body": { "mode": "formdata", "formdata": [{ "key": "category_id", "value": "CATEGORY_ID_HERE", "type": "text" }, { "key": "name", "value": "DSLR Camera - Canon EOS 90D", "type": "text" }, { "key": "description", "value": "High quality DSLR camera for photography", "type": "text" }, { "key": "specification", "value": "32.5MP, 4K Video, ISO 100-25600", "type": "text" }, { "key": "price", "value": "800", "type": "text" }, { "key": "total_qty", "value": "5", "type": "text" }, { "key": "image", "src": "", "type": "file" }] } } },
        { "name": "Update Equipment (with image)", "request": { "method": "POST", "url": { "raw": "{{base_url}}/admin/updateEquipment", "host": ["{{base_url}}"], "path": ["admin", "updateEquipment"] }, "body": { "mode": "formdata", "formdata": [{ "key": "id", "value": "EQUIPMENT_ID_HERE", "type": "text" }, { "key": "name", "value": "DSLR Camera - Canon EOS 90D V2", "type": "text" }, { "key": "price", "value": "900", "type": "text" }, { "key": "status", "value": "Available", "type": "text" }, { "key": "image", "src": "", "type": "file" }] } } },
        { "name": "Delete Equipment", "request": { "method": "GET", "url": { "raw": "{{base_url}}/admin/deleteEquipment/EQUIPMENT_ID_HERE", "host": ["{{base_url}}"], "path": ["admin", "deleteEquipment", "EQUIPMENT_ID_HERE"] } } },
        { "name": "Get All Equipment (Admin)", "request": { "method": "GET", "url": { "raw": "{{base_url}}/admin/equipment", "host": ["{{base_url}}"], "path": ["admin", "equipment"] } } },
        { "name": "Get All Bookings", "request": { "method": "GET", "url": { "raw": "{{base_url}}/admin/bookings", "host": ["{{base_url}}"], "path": ["admin", "bookings"] } } },
        { "name": "Update Booking (Approve)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/admin/updateBooking", "host": ["{{base_url}}"], "path": ["admin", "updateBooking"] }, "body": { "mode": "raw", "raw": "{\n  \"id\": \"BOOKING_ID_HERE\",\n  \"status\": \"Approved\"\n}" } } },
        { "name": "Update Booking (Cancel)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{base_url}}/admin/updateBooking", "host": ["{{base_url}}"], "path": ["admin", "updateBooking"] }, "body": { "mode": "raw", "raw": "{\n  \"id\": \"BOOKING_ID_HERE\",\n  \"status\": \"Cancelled\"\n}" } } },
        { "name": "Get All Payments", "request": { "method": "GET", "url": { "raw": "{{base_url}}/admin/payments", "host": ["{{base_url}}"], "path": ["admin", "payments"] } } },
        { "name": "Get All Feedbacks (Admin)", "request": { "method": "GET", "url": { "raw": "{{base_url}}/admin/feedbacks", "host": ["{{base_url}}"], "path": ["admin", "feedbacks"] } } },
        { "name": "Dashboard Stats", "request": { "method": "GET", "url": { "raw": "{{base_url}}/admin/dashboardStats", "host": ["{{base_url}}"], "path": ["admin", "dashboardStats"] } } }
      ]
    }
  ]
}
